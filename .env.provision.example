# One-time provisioning credentials for `npm run provision:supabase`.
# Copy this file to .env.provision (gitignored) and fill in SUPABASE_ACCESS_TOKEN.
#
#   cp .env.provision.example .env.provision
#
# NOTE: SUPABASE_ACCESS_TOKEN here is your *Personal Access Token* (the key the
# Management API authenticates with). It is NOT the same as the SUPABASE_ACCESS_TOKEN
# written to .env.local — that one is the project's service_role key, set by the script.

# Required — Supabase Personal Access Token. Generate at:
#   https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=sbp_xxx

# Optional — organization to create the project in.
# Leave blank to auto-pick when your account has exactly one org.
SUPABASE_ORG_ID=

# Optional — AWS region slug for the new project. Defaults to us-east-1.
SUPABASE_REGION=us-east-1

# Optional — database password. Leave blank: the script generates a strong one
# and writes it back here so re-runs can rebuild connection strings.
SUPABASE_DB_PASSWORD=
