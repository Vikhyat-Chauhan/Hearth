# Hearth — required environment variables.
# Copy to .env.local for local dev (gitignored), and set these in the Vercel
# project (Production + Preview) before deploying. assertServerEnv() (src/lib/env.ts)
# checks the required ones at runtime and aborts a misconfigured production boot.

# --- Database (Supabase Postgres) ---
# App runtime: the transaction pooler (port 6543). prepare:false is required.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/postgres
# Migrations only (drizzle-kit): the session pooler / direct connection (port 5432).
DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/postgres

# --- Supabase Auth (public — safe to expose to the browser) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# --- Google OAuth app (server-only secrets; same app wired into Supabase) ---
GOOGLE_CLIENT_ID=YOUR_GOOGLE_OAUTH_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_OAUTH_CLIENT_SECRET

# --- Token encryption (server-only) ---
# Encrypts each user's Google refresh token at rest. 32 bytes, hex or base64.
# Generate with: openssl rand -hex 32
TOKEN_ENC_KEY=YOUR_32_BYTE_HEX_OR_BASE64_KEY

# --- Email notifications (server-only, optional) ---
# Resend powers announcement emails and the daily due-chore digest. If these are
# unset the app still runs; email sends are logged and skipped (best-effort).
RESEND_API_KEY=YOUR_RESEND_API_KEY
# Verified sender, e.g. "Hearth <notifications@yourdomain.com>".
EMAIL_FROM=Hearth <notifications@yourdomain.com>

# --- Cron (server-only, optional) ---
# Bearer token guarding /api/cron/due-chores. Vercel injects this as the
# Authorization header on scheduled runs when CRON_SECRET is set on the project.
# Generate with: openssl rand -hex 32
CRON_SECRET=YOUR_CRON_SECRET
