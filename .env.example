# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
SUPABASE_ACCESS_TOKEN=<service-role-or-access-token>

# Database (Drizzle / Supabase Postgres)
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:6543/postgres?pgmode=transaction
DIRECT_URL=postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email (Resend) — required only if email features are used
RESEND_API_KEY=re_<key>
RESEND_FROM_EMAIL=noreply@yourdomain.com
EMAIL_FROM=noreply@yourdomain.com

# Testing — local dev only, never commit real credentials
TEST_EMAIL=test@example.com
TEST_PASSWORD=changeme
